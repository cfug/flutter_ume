# Exclude large files that shouldn't be published
plugins.zip
*.zip

# Exclude cyclop docs (web build artifacts)
kits/flutter_ume_kit_ui/lib/third_party/cyclop/docs/
kits/flutter_ume_kit_ui/lib/third_party/cyclop/tools/

